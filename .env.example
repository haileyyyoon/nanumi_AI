# Copy this file to .env and fill in your own values.
# Never commit your real .env file to version control.

# --- Required ---

# OpenAI API key, used to generate chatbot answers.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Pinecone API key, used for the vector search index.
# Get one at https://app.pinecone.io
PINECONE_API_KEY=pcsk_...

# A random secret string Flask uses to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me_to_a_long_random_string

# --- Optional (defaults shown) ---

# OpenAI chat model used to answer questions.
# OPENAI_MODEL=gpt-4o-mini

# Name of the Pinecone index this app creates/uses.
# PINECONE_INDEX_NAME=comfort-women-rag

# Pinecone namespace within that index.
# PINECONE_NAMESPACE=ns1

# How many chunks to retrieve per question.
# RAG_TOP_K=5

# How many past messages to keep per chat session.
# MAX_CHAT_HISTORY=20

# Longest question (in characters) the server will accept.
# MAX_QUESTION_LENGTH=500

# Rate limits protecting your OpenAI account from a public URL being abused.
# Per-visitor (per IP). Also set a monthly budget limit in the OpenAI
# dashboard as the real hard ceiling on spend.
# CHAT_RATE_LIMIT=20 per minute;200 per hour
# FEEDBACK_RATE_LIMIT=30 per minute

# Worksheet tab where visitor-flagged answers are logged.
# GOOGLE_SHEET_FEEDBACK_WORKSHEET_NAME=Feedback

# Set to "true" to enable Flask's debug/auto-reload mode locally.
# Never enable this in production.
# FLASK_DEBUG=false

# Port the Flask dev server listens on.
# PORT=5000

# --- Optional: log Q&A pairs to a Google Sheet ---
# Leave both unset to disable this feature entirely (the chatbot works fine
# without it). See README.md for how to create the service account and
# share your Sheet with it.

# Path to the Google service account JSON key file. Locally this can be a
# file in the project folder (make sure it's gitignored). On Render, use a
# "Secret File" and point this at its mounted path instead.
# GOOGLE_SHEETS_CREDENTIALS_PATH=google_credentials.json

# The target spreadsheet's ID — the long string in its URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
# GOOGLE_SHEET_ID=

# Name of the worksheet (tab) to log to. Created automatically with headers
# if it doesn't already exist.
# GOOGLE_SHEET_WORKSHEET_NAME=Sheet1
