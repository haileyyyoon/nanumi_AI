# Copy this file to .env and fill in your own values.
# Never commit your real .env file to version control.

# --- Required ---

# OpenAI API key, used to generate chatbot answers.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Pinecone API key, used for the vector search index.
# Get one at https://app.pinecone.io
PINECONE_API_KEY=pcsk_...

# A random secret string Flask uses to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me_to_a_long_random_string

# --- Optional (defaults shown) ---

# OpenAI chat model used to answer questions.
# OPENAI_MODEL=gpt-4o-mini

# Name of the Pinecone index this app creates/uses.
# PINECONE_INDEX_NAME=comfort-women-rag

# Pinecone namespace within that index.
# PINECONE_NAMESPACE=ns1

# How many chunks to retrieve per question.
# RAG_TOP_K=5

# How many past messages to keep per chat session.
# MAX_CHAT_HISTORY=20

# Set to "true" to enable Flask's debug/auto-reload mode locally.
# Never enable this in production.
# FLASK_DEBUG=false

# Port the Flask dev server listens on.
# PORT=5000
